# SkillFlux env reference.
# Production [vars] live in wrangler.toml; secrets go via `wrangler secret put`.
# For LOCAL development, copy the dev-only values below into `.dev.vars`
# (git-ignored) — wrangler pages dev loads them automatically.

SITE_URL=http://localhost:8788
SKILLFLUX_PRODUCT=deluxe-pack

# Dev-only: enables the fixture bypass. Only honored on non-production hosts
# (see functions/lib/fixture.ts). NEVER set this for the production deploy.
# Put this line in `.dev.vars`, not wrangler.toml:
SKILLFLUX_FIXTURE_MODE=1

# GitHub OAuth (production)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Stripe subscription billing (production)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Recurring Price ids for the two billing periods:
# STRIPE_PRICE_MONTHLY=
# STRIPE_PRICE_ANNUAL=

# Optional dev bypass token
# SKILLFLUX_API_DEV_TOKEN=

# MCP client (skillflux-pack)
# SKILLFLUX_API_URL=http://localhost:8788/api
# SKILLFLUX_FIXTURE=0
